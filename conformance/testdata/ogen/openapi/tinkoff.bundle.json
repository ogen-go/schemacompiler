        "faceValue": {
          "type": "number",
          "format": "double",
          "description": "Номинал для облигаций"
        },
        "lastPrice": {
          "type": "number",
          "format": "double"
        },
        "closePrice": {
          "type": "number",
          "format": "double"
        },
        "limitUp": {
          "type": "number",
          "format": "double",
