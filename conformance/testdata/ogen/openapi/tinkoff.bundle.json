        "figi": {
          "type": "string"
        },
        "depth": {
          "type": "integer",
          "format": "int32"
        },
        "bids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/OrderResponse"
          }
        },
        "asks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/OrderResponse"
          }
        },
        "tradeStatus": {
          "$ref": "#/$defs/TradeStatus"
        },
        "minPriceIncrement": {
          "type": "number",
          "format": "double",
