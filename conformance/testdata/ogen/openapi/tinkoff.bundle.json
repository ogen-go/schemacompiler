      "type": "string",
      "enum": [
        "Buy",
        "BuyCard",
        "Sell",
        "BrokerCommission",
        "ExchangeCommission",
        "ServiceCommission",
        "MarginCommission",
        "OtherCommission",
        "PayIn",
        "PayOut",
        "Tax",
        "TaxLucre",
        "TaxDividend",
        "TaxCoupon",
        "TaxBack",
        "Repayment",
        "PartRepayment",
